{
  "name": "college-emmanuel-electron",
  "version": "1.0.0",
  "description": "Application desktop du Collège Emmanuel",
  "author": "Jonathan Muembia",
  "private": true,

  "main": "main.js",

  "scripts": {
    "dev": "electron .",
    "build": "electron-builder"
  },

  "devDependencies": {
    "electron": "41.7.1",
    "electron-builder": "^26.15.3"
  },


  "build": {

    "appId": "com.college.emmanuel",

    "productName": "College Emmanuel",


    "directories": {
      "output": "dist"
    },


    "files": [
      "main.js",
      "package.json"
    ],


    "extraResources": [

      {
        "from": "../backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },


      {
        "from": "../frontend/dist",
        "to": "frontend",
        "filter": [
          "**/*"
        ]
      }

    ],


    "win": {

      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],


      "icon": "assets/logo.ico"

    },


    "nsis": {

      "oneClick": false,

      "allowToChangeInstallationDirectory": true,

      "createDesktopShortcut": true,

      "createStartMenuShortcut": true

    }

  }
}